OCTYNE_API_KEYS=
OCTYNE_PROVIDERS=openai
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODELS=gpt-4.1-mini,gpt-5-nano
OPENAI_NON_STREAMING_TIMEOUT=10m
OPENAI_STREAMING_RESPONSE_HEADER_TIMEOUT=30s
PORT=3000

# Local Ollama example:
# OCTYNE_PROVIDERS=openai,ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_API_KEY=
# OLLAMA_MODELS=llama3.2
# OLLAMA_NON_STREAMING_TIMEOUT=10m
# OLLAMA_STREAMING_RESPONSE_HEADER_TIMEOUT=30s
